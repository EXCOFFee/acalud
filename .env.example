# =============================================================================
# Acalud — variables de entorno (plantilla)
# Copiar a .env y completar. NUNCA versionar .env (ADR-005 §7; scanner de CI bloquea).
# Los valores reales de producción viven en el panel de Vercel/Render, no acá.
# =============================================================================

# --- Entorno ---
NODE_ENV=development
API_PORT=3000

# --- URLs de la app (transporte dual de sesión, ADR-004) ---
WEB_BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:3000

# --- Base de datos: PostgreSQL gestionado en Supabase (ADR-003) ---
# DATABASE_URL usa el pooler; DIRECT_URL apunta directo para migraciones.
DATABASE_URL=postgresql://usuario:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://usuario:password@host:5432/postgres

# --- Supabase Storage (recursos, comprobantes, imágenes, adjuntos) ---
# Acceso SOLO desde el backend con service-role (ADR-003, RLS deny-all).
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Autenticación propia (ADR-004) ---
# Secreto para firmar/derivar el token opaco de sesión. Obligatorio en producción.
SESSION_SECRET=cambiar-esto-por-un-secreto-largo-aleatorio
SESSION_COOKIE_NAME=acalud_sesion

# --- Mercado Pago (sandbox, ADR-006 / R-02). Sin fallback por diseño. ---
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# --- Correo Argentino MiCorreo (ambiente test, ADR-006). Fallback: tabla local. ---
# SHIPPING_ADAPTER=micorreo usa la API real; =tabla fuerza el fallback local.
SHIPPING_ADAPTER=tabla
MICORREO_TOKEN=

# --- ARCA WSFEv1 (homologación, ADR-006 / R-03). Fallback: PDF interno. ---
# RECEIPT_ARCA_ENABLED=false → solo PDF interno; =true activa el adapter SOAP.
RECEIPT_ARCA_ENABLED=false
ARCA_CUIT=
# El certificado y la clave privada entran por secret files de Render, no como texto acá.
ARCA_CERT_PATH=
ARCA_KEY_PATH=

# --- Email transaccional (ADR-006; Resend o Brevo, se decide en 5.1). ---
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=no-reply@acalud.example
