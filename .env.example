# Configuración básica para AcaLud
# Copia este archivo como .env y ajusta los valores según tu entorno

# ============================================================================
# BASE DE DATOS
# ============================================================================
POSTGRES_DB=acalud
POSTGRES_USER=acalud_user
POSTGRES_PASSWORD=acalud_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================================================
# AUTENTICACIÓN
# ============================================================================
JWT_SECRET=acalud_super_secret_jwt_key_2024_change_in_production
JWT_EXPIRES_IN=24h

# ============================================================================
# REDIS (CACHE)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# URLs
# ============================================================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# ============================================================================
# ENTORNO
# ============================================================================
NODE_ENV=development

# ============================================================================
# CONFIGURACIÓN ADICIONAL
# ============================================================================
# Descomenta y ajusta según necesites:

# Puerto del backend (por defecto 3000 interno, 3001 externo)
# BACKEND_PORT=3000

# Configuración de email (si implementas notificaciones)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_email@gmail.com
# SMTP_PASS=tu_password

# Configuración de archivos
# MAX_FILE_SIZE=5MB
# UPLOAD_PATH=./uploads