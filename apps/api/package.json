{
  "name": "@acalud/api",
  "version": "0.1.0",
  "private": true,
  "description": "API monolito modular hexagonal de Acalud (NestJS). Un módulo por bounded context (2.3).",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "deps:boundaries": "depcruise src --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.17.0",
    "supertest": "^7.0.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.0"
  }
}
