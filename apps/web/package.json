{
  "name": "@acalud/web",
  "version": "0.1.0",
  "private": true,
  "description": "UI única de Acalud (Next.js static export). El mismo bundle produce la web y la APK (Capacitor, ADR-001).",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "vitest run --passWithNoTests",
    "cap:sync": "cap sync android"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.0"
  }
}
