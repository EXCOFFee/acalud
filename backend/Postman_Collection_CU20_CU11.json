          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('New avatar URL is different', function () {",
                  "    const response = pm.response.json();",
                  "    const oldAvatar = pm.environment.get('oldAvatar');",
                  "    if (oldAvatar) {",
                  "        pm.expect(response.avatar).to.not.equal(oldAvatar);",
                  "    }",
                  "});",
                  "",
                  "console.log('🗑️ Verifica en el backend que el avatar anterior fue eliminado del disco');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Guardar avatar actual antes de reemplazar",
                  "pm.sendRequest({",
                  "    url: pm.environment.get('baseUrl') + '/users/profile',",
                  "    method: 'GET',",
                  "    header: {",
                  "        'Authorization': 'Bearer ' + pm.environment.get('teacherToken')",
                  "    }",
                  "}, function (err, response) {",
                  "    if (response && response.json().avatar) {",
                  "        pm.environment.set('oldAvatar', response.json().avatar);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
