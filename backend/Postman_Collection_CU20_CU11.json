              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('teacherToken', response.access_token);",
                  "    pm.environment.set('teacherId', response.user.id);",
                  "    console.log('✅ Teacher token guardado:', response.access_token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
