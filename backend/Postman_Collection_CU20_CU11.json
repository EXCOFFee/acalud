      "name": "CU-20: Agregar Actividad",
      "item": [
        {
          "name": "✅ 1. Success - Add Activity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains activities array', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('activities');",
                  "    pm.expect(response.activities).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Activity was added', function () {",
                  "    const response = pm.response.json();",
                  "    const activityId = pm.environment.get('activityId');",
                  "    const found = response.activities.some(a => a.id === activityId);",
                  "    pm.expect(found).to.be.true;",
