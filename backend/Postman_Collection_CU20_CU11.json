                  "pm.test('Response has avatar URL', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('avatar');",
                  "    pm.expect(response.avatar).to.include('/uploads/avatars/');",
                  "});",
